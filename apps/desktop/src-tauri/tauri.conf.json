{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeepSeek Agent OS",
  "version": "0.1.0",
  "identifier": "ai.deepseek-agent-os.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
